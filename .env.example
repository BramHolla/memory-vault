# Kopieer dit bestand naar .env en vul de waarden in
# Het .env bestand wordt NOOIT gecommit (staat in .gitignore)

# Wachtwoord voor de login pagina
APP_PASSWORD=kies_een_sterk_wachtwoord

# Flask sessie encryptie sleutel
# Genereer met: python -c "import secrets; print(secrets.token_hex(32))"
FLASK_SECRET_KEY=

# Cloudflare R2 credentials
# Te vinden in: Cloudflare dashboard → R2 → Manage R2 API Tokens
R2_ACCOUNT_ID=
R2_ACCESS_KEY=
R2_SECRET_KEY=
R2_BUCKET_NAME=memoryvault

# Publieke URL van de R2 bucket
# Te vinden in: Cloudflare dashboard → R2 → jouw bucket → Settings → Public Access
R2_PUBLIC_URL=https://pub-XXXXXXXXXXXXXXXXXXXX.r2.dev