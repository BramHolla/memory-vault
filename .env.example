# Copy this file to .env and fill in your values.
# The .env file is NEVER committed (it is listed in .gitignore).

# Flask session encryption key
# Generate with: python -c "import secrets; print(secrets.token_hex(32))"
FLASK_SECRET_KEY=

# Cloudflare R2 credentials
# Find these in: Cloudflare dashboard → R2 → Manage R2 API Tokens
R2_ACCOUNT_ID=
R2_ACCESS_KEY=
R2_SECRET_KEY=
R2_BUCKET_NAME=your-bucket-name

# Public URL of your R2 bucket
# Find in: Cloudflare dashboard → R2 → your bucket → Settings → Public Access
R2_PUBLIC_URL=https://pub-XXXXXXXXXXXXXXXXXXXX.r2.dev

# Gmail SMTP (for invite and password reset emails)
# Use a Gmail App Password, not your regular password
GMAIL_USER=your@gmail.com
GMAIL_APP_PASSWORD=
